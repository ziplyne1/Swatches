# Xcode user data (always ignore)
xcuserdata/
*.xcuserstate

# Build artifacts
DerivedData/
.build/

# App build products
*.ipa
*.dSYM
*.dSYM.zip

# macOS system files
.DS_Store


# --- Optional (uncomment if needed) ---

# Swift Package Manager
# Ignore downloaded dependencies (only if you want to re-resolve on every clone)
# .build/
# Packages/

# Keep this COMMITTED for reproducible builds (recommended):
# Package.resolved

# CocoaPods
# Uncomment if you do NOT want to commit Pods (generally not recommended)
# Pods/

# Carthage
# Uncomment if using Carthage and want to ignore built dependencies
# Carthage/Build/